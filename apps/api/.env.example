# --- Database (Neon serverless Postgres) ---
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Auth ---
# Generate each with: openssl rand -hex 32   (the two must differ)
JWT_ACCESS_SECRET=change-me-64-hex-chars
JWT_REFRESH_SECRET=change-me-64-hex-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Server ---
PORT=4000
NODE_ENV=development
# Required in production — the API refuses to boot without it.
FRONTEND_ORIGIN=http://localhost:3000

# --- Deployment ---
# Set to 1 only when behind a reverse proxy (Vercel, Render, nginx). Trusting
# X-Forwarded-For while directly exposed lets clients spoof their IP and bypass
# rate limiting; leaving it unset behind a proxy makes every request look like
# it came from one IP, so the limiter throttles all users together.
TRUST_PROXY=

# Set to true only when the web app and the API are on different registrable
# domains (e.g. both on *.vercel.app), which forces the refresh cookie to
# SameSite=None. On a shared parent domain leave unset to keep the stricter
# SameSite=Strict.
CROSS_SITE_COOKIES=

# Leave unset. Setting this to true in production disables the guard that
# blocks fake payment confirmation — anyone could grant themselves a paid plan.
PAYMENTS_DEMO_MODE=
